# ─── Postgres ───────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=reventa
POSTGRES_USER=reventa_user
POSTGRES_PASSWORD=changeme

# ─── Backend ────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=changeme-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development

# ─── Super Admin (seeded on first deploy) ───────────────────
ADMIN_EMAIL=admin@reventa.com
ADMIN_PASSWORD=changeme-strong-password
ADMIN_NAME=Super Admin

# ─── AWS / S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_BUCKET=reventa-vehicles
# LocalStack for local dev — remove in production
S3_ENDPOINT_URL=http://localstack:4566

# ─── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
